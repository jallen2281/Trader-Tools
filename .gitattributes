# Normalize all text files to LF in the repo.
# Windows working tree files stay CRLF if core.autocrlf=true,
# but the committed objects always contain LF.
* text=auto eol=lf

# Explicitly binary — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.db  binary
*.dump binary
